#!/bin/bash
# Двойной клик → запускается Terminal → выполняется команда установки.
# Курс-токен запрашивается интерактивно установщиком (не передаётся
# через этот скрипт — безопасность).
#
# Wave 13 — DMG-установщик для macOS. Скрипт всего лишь обёртка над
# bash <(curl ...) командой. Вся логика установки — в openclaw-factory
# на стороне сервера.

# Закроем терминал чисто чтобы предыдущий вывод не мешал
clear

cat <<'BANNER'
═══════════════════════════════════════════════════════════
  ШАГ 1 из 2 — Установка OpenClaw (движок)
  Займёт примерно 5-10 минут
═══════════════════════════════════════════════════════════

Сейчас откроется процесс установки. Что от тебя нужно:

  1. Когда попросит курс-токен → вставь его
     (получи в Telegram: @AITeamVIPBot → /start → email/телефон)

  2. Когда попросит API-ключ модели → найди в материалах курса

  3. Когда попросит токен бота → создай в Telegram:
     @BotFather → /newbot → следуй инструкциям

Если что-то пойдёт не так — закрой это окно и снова открой DMG.

═══════════════════════════════════════════════════════════
BANNER

echo ""
read -p "Готов? Нажми Enter чтобы начать..." _

echo ""
echo "Запускаю установщик..."
echo ""

# Запускаем первый установщик. Он сам спросит курс-токен и всё
# остальное. Если интернет недоступен — он сам выдаст понятное
# сообщение.
bash <(curl -fsSL https://raw.githubusercontent.com/tonytrue92-beep/openclaw-factory/main/scripts/demo-install.sh)
_INSTALL_RC=$?

echo ""
echo "═══════════════════════════════════════════════════════════"
if [[ $_INSTALL_RC -eq 0 ]]; then
  cat <<'DONE'
  ✓ ШАГ 1 завершён.

  Дальше:
  1. Закрой это окно (или оставь открытым — не помешает)
  2. Вернись в DMG-окно (Finder)
  3. Запусти "2. Установить AI-команду.command" двойным кликом
DONE
else
  cat <<'FAIL'
  ✗ Установщик завершился с ошибкой (код: '"$_INSTALL_RC"').

  Что делать:
  1. Прочитай вывод выше — там должно быть понятное сообщение.
  2. Если непонятно — собери debug-bundle для саппорта:
     bash <(curl -fsSL https://raw.githubusercontent.com/tonytrue92-beep/openclaw-factory/main/scripts/demo-install.sh) --collect-debug
  3. Пришли zip-файл в саппорт-чат курса.
FAIL
fi
echo "═══════════════════════════════════════════════════════════"

echo ""
read -p "Нажми Enter чтобы закрыть это окно..." _
